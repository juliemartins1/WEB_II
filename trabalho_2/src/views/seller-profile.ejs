<!doctype html>
<html lang="pt-BR">

<head>
    <title>MarketMVP | Perfil do vendedor</title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
        <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
            <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
                <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
                <nav class="flex items-center gap-5 text-sm font-medium">
                    <a href="/seller" class="hover:text-accent-600">Painel</a>
                    <form method="POST" action="/logout">
                        <button type="submit" class="hover:text-accent-600">Sair</button>
                    </form>
                </nav>
            </div>
        </header>

        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
            <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Perfil: Vendedor</p>
                <h1 class="mt-1 font-display text-3xl font-bold">Dados da loja</h1>
                <p class="mt-2 text-sm text-brand-700">Essas informações aparecem publicamente nos seus produtos.</p>

                <% if (typeof success !=='undefined' && success) { %>
                    <p class="mt-3 rounded-xl bg-accent-500/10 px-4 py-2 text-sm font-semibold text-accent-600">
                        <%= success %>
                    </p>
                    <% } %>

                        <% if (typeof error !=='undefined' && error) { %>
                            <p class="mt-3 rounded-xl bg-coral-500/10 px-4 py-2 text-sm font-semibold text-coral-600">
                                <%= error %>
                            </p>
                            <% } %>

                                <form method="POST" action="/profiles/seller" class="mt-5 grid gap-4 sm:grid-cols-2">
                                    <label class="block sm:col-span-2">
                                        <span class="mb-1 block text-sm font-medium">Nome da loja</span>
                                        <input name="storeName" required value="<%= profile?.storeName || '' %>"
                                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                    </label>

                                    <label class="block sm:col-span-2">
                                        <span class="mb-1 block text-sm font-medium">Descrição</span>
                                        <textarea name="description" required
                                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring"><%= profile?.description || '' %></textarea>
                                    </label>

                                    <label class="block">
                                        <span class="mb-1 block text-sm font-medium">Telefone comercial</span>
                                        <input name="commercialPhone" required
                                            value="<%= profile?.commercialPhone || '' %>"
                                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                    </label>

                                    <label class="block">
                                        <span class="mb-1 block text-sm font-medium">Categorias de produtos</span>
                                        <div>
                                                                                
                                            <select name="categories" required
                                                class="w-full rounded-2xl border border-brand-200 p-3 outline-none focus:border-black">
                                                
                                        
                                                <option value="Eletrônicos" <%=profile?.categories==='Eletrônicos' ? 'selected' : '' %>>
                                                    Eletrônicos
                                                </option>
                                        
                                                <option value="Casa e decoração" <%=profile?.categories==='Casa e decoração' ? 'selected' : '' %>>
                                                    Casa e decoração
                                                </option>
                                        
                                                <option value="Moda" <%=profile?.categories==='Moda' ? 'selected' : '' %>>
                                                    Moda
                                                </option>
                                        
                                                <option value="Esportes" <%=profile?.categories==='Esportes' ? 'selected' : '' %>>
                                                    Esportes
                                                </option>
                                        
                                                <option value="Beleza" <%=profile?.categories==='Beleza' ? 'selected' : '' %>>
                                                    Beleza
                                                </option>
                                        
                                                <option value="Automotivo" <%=profile?.categories==='Automotivo' ? 'selected' : '' %>>
                                                    Automotivo
                                                </option>
                                        
                                                <option value="Outros" <%=profile?.categories==='Outros' ? 'selected' : '' %>>
                                                    Outros
                                                </option>
                                            </select>
                                        </div>
                                    </label>

                                    <label class="block">
                                        <span class="mb-1 block text-sm font-medium">Cidade</span>
                                        <input name="city" required value="<%= profile?.city || '' %>"
                                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                    </label>

                                    <label class="block">
                                        <span class="mb-1 block text-sm font-medium">Estado</span>
                                        <input name="state" required maxlength="2" value="<%= profile?.state || '' %>"
                                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                    </label>

                                    <button
                                        class="sm:col-span-2 rounded-xl bg-accent-500 px-5 py-2.5 font-semibold text-black hover:bg-accent-600">
                                        Salvar perfil
                                    </button>
                                </form>
            </section>
        </main>
    </div>
</body>

</html>