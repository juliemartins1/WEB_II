<!doctype html>
<html lang="pt-BR">

<head>
  <title>Categorias</title>
  <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">

    <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">

      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">
          Marketplace
        </p>

        <h1 class="mt-1 font-display text-3xl font-bold">
          Navegue pelas categorias
        </h1>

        <p class="mt-1 text-sm text-brand-700">
          Escolha uma categoria para visualizar somente os produtos relacionados.
        </p>

        <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">

          <a href="/categories"
            class="rounded-xl px-4 py-3 text-left font-semibold transition
                        <%= !categoriaSelecionada ? 'bg-coral-600 text-white' : 'bg-brand-100 text-brand-900 hover:bg-brand-200' %>">
            Todas
          </a>

          <% categorias.forEach(function(categoria) { %>
            <a href="/categories?category=<%= encodeURIComponent(categoria) %>"
              class="rounded-xl px-4 py-3 text-left font-semibold transition
                            <%= categoriaSelecionada === categoria ? 'bg-coral-600 text-white' : 'bg-brand-100 text-brand-900 hover:bg-brand-200' %>">
              <%= categoria %>
            </a>
            <% }) %>

        </div>
      </section>

      <section>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="font-display text-2xl font-bold">
            <% if (categoriaSelecionada) { %>
              Produtos em <%= categoriaSelecionada %>
                <% } else { %>
                  Todos os produtos
                  <% } %>
          </h2>

          <a href="/" class="rounded-xl border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">
            Voltar ao início
          </a>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

          <% if (!products || products.length===0) { %>
            <div class="rounded-2xl border border-brand-200 bg-white p-6 shadow-sm sm:col-span-2 lg:col-span-3">
              <p class="text-brand-700">
                Nenhum produto encontrado nessa categoria.
              </p>
            </div>
            <% } %>

              <% products.forEach(function(product) { %>
                <article class="rounded-2xl border border-brand-200 bg-white p-4 shadow-sm hover-scale">

                  <% if (product.imageUrl) { %>
                    <img src="<%= product.imageUrl %>"
                      class="mb-3 h-44 w-full rounded-xl object-cover border border-brand-200" alt="Imagem do produto">
                    <% } else { %>
                      <div
                        class="mb-3 flex h-44 w-full items-center justify-center rounded-xl border border-brand-200 bg-brand-100 text-sm text-brand-600">
                        Sem imagem
                      </div>
                      <% } %>

                        <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">
                          <%= product.category %>
                        </p>

                        <h3 class="mt-1 font-display text-lg font-bold">
                          <%= product.name %>
                        </h3>

                        <p class="mt-1 text-sm text-brand-700 line-clamp-2">
                          <%= product.description %>
                        </p>

                        <p class="mt-2 text-sm text-brand-700">
                          Vendedor:
                          <strong>
                            <%= product.user.sellerProfile?.storeName || product.user.name %>
                          </strong>
                        </p>

                        <div class="mt-3 flex items-center justify-between">
                          <span class="font-bold text-coral-600">
                            R$ <%= Number(product.price).toFixed(2).replace('.', ',' ) %>
                          </span>

                          <a href="/products/<%= product.id %>"
                            class="rounded-lg border border-brand-300 px-3 py-1.5 text-sm font-semibold hover:bg-brand-100">
                            Ver detalhes
                          </a>
                        </div>

                </article>
                <% }) %>

        </div>
      </section>

    </main>
  </div>
</body>

</html>