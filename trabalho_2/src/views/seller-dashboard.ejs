<!doctype html>
<html lang="pt-BR">

<head>
  <title>MarketMVP | Painel do vendedor</title>
  <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">

    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="font-display text-xl font-bold">MarketMVP</a>

        <nav class="flex items-center gap-5 text-sm font-medium">
          <span class="text-brand-600">Olá, <%= user.name %></span>

          <a href="/profiles/seller" class="hover:text-accent-600">
            Perfil da loja
          </a>

          <a href="/seller/products/new" class="hover:text-accent-600">
            Novo produto
          </a>

          <form method="POST" action="/logout">
            <button type="submit" class="hover:text-accent-600">
              Sair
            </button>
          </form>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">

      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">
          Perfil: Vendedor
        </p>

        <h1 class="mt-1 font-display text-3xl font-bold">
          Painel do vendedor
        </h1>

        <p class="mt-2 text-sm text-brand-700">
          Gerencie seus produtos, vendas e perfil da loja.
        </p>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">

          <!-- RECEITA -->
          <div class="rounded-2xl bg-brand-100 p-4">
            <p class="text-xs font-semibold uppercase tracking-wider">
              Receita
            </p>

            <p class="mt-2 font-display text-3xl font-bold">
              R$ 0
            </p>
          </div>

          <!-- PEDIDOS -->
          <div class="rounded-2xl bg-brand-100 p-4">
            <p class="text-xs font-semibold uppercase tracking-wider">
              Pedidos pendentes
            </p>

            <p class="mt-2 font-display text-3xl font-bold">
              0
            </p>
          </div>

          <!-- PRODUTOS -->
          <div class="rounded-2xl bg-brand-100 p-4">
            <p class="text-xs font-semibold uppercase tracking-wider">
              Produtos ativos
            </p>

            <p class="mt-2 font-display text-3xl font-bold">
              <%= produtosAtivos %>
            </p>
          </div>

        </div>
      </section>

      <!-- AÇÕES -->
      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">

        <h2 class="font-display text-2xl font-bold">
          Ações rápidas
        </h2>

        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

          <!-- NOVO PRODUTO -->
          <a href="/seller/products/new" class="rounded-2xl border border-brand-200 bg-brand-50 p-4 hover:bg-brand-100">
            <h3 class="font-semibold">
              Cadastrar produto
            </h3>

            <p class="text-sm text-brand-700">
              Adicione novos produtos à loja
            </p>
          </a>

          <!-- PERFIL -->
          <a href="/profiles/seller" class="rounded-2xl border border-brand-200 bg-brand-50 p-4 hover:bg-brand-100">
            <h3 class="font-semibold">
              Perfil da loja
            </h3>

            <p class="text-sm text-brand-700">
              Atualize informações públicas
            </p>
          </a>

          <!-- MARKETPLACE -->
          <a href="/marketplace" class="rounded-2xl border border-brand-200 bg-brand-50 p-4 hover:bg-brand-100">
            <h3 class="font-semibold">
              Ver marketplace
            </h3>

            <p class="text-sm text-brand-700">
              Visualizar produtos cadastrados
            </p>
          </a>

        </div>
      </section>

    </main>
  </div>
</body>

</html>