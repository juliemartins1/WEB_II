<!doctype html>
<html lang="pt-BR">

<head>
  <title> Detalhes do produto</title>
  <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">
      <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
      <section class="grid gap-6 rounded-3xl border border-brand-200 bg-white p-6 shadow-sm md:grid-cols-2">
        <div>
          <% if (product.imageUrl) { %>
            <img src="<%= product.imageUrl %>" class="h-80 w-full rounded-2xl object-cover border border-brand-200">
            <% } else { %>
              <div class="flex h-80 items-center justify-center rounded-2xl bg-brand-100 text-brand-700">
                Sem imagem principal
              </div>
              <% } %>

                <div class="mt-4 grid grid-cols-3 gap-3">
                  <% product.images.forEach(img=> { %>
                    <img src="<%= img.imageUrl %>" class="h-28 w-full rounded-xl object-cover border border-brand-200">
                    <% }) %>
                </div>
        </div>

        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">
            <%= product.category %>
          </p>

          <h1 class="mt-1 font-display text-3xl font-bold">
            <%= product.name %>
          </h1>

          <p class="mt-3 text-brand-700">
            <%= product.description %>
          </p>

          <p class="mt-5 font-display text-4xl font-bold text-coral-600">
            R$ <%= Number(product.price).toFixed(2).replace('.', ',' ) %>
          </p>

          <p class="mt-2 text-sm text-brand-700">
            Estoque disponível: <strong>
              <%= product.stock %>
           <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
        <nav class="flex items-center gap-5 text-sm font-medium">
          </strong>
          </p>

          <div class="mt-6 rounded-2xl bg-brand-100 p-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Vendedor</p>

            <h2 class="mt-1 font-display text-xl font-bold">
              <%= product.user.sellerProfile?.storeName || product.user.name %>
            </h2>

            <% if (product.user.sellerProfile) { %>
              <p class="mt-2 text-sm text-brand-700">
                <%= product.user.sellerProfile.description %>
              </p>

              <p class="mt-2 text-sm text-brand-700">
                <strong>Contato:</strong>
                <%= product.user.sellerProfile.commercialPhone %>
              </p>

              <p class="text-sm text-brand-700">
                <strong>Localização:</strong>
                <%= product.user.sellerProfile.city %> - <%= product.user.sellerProfile.state %>
              </p>

              <p class="text-sm text-brand-700">
                <strong>Categorias:</strong>
                <%= product.user.sellerProfile.categories %>
              </p>
              <% } %>

                <a href="/sellers/<%= product.user.id %>"
                  class="mt-4 inline-block rounded-xl border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">
                  Ver perfil do vendedor
                </a>
          </div>
        </div>
      </section>

      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Interações</p>
            <h2 class="font-display text-2xl font-bold">Comentários</h2>
            <p class="mt-1 text-sm text-brand-700">
              Total de curtidas nos comentários: <strong>
                <%= totalLikes %>
              </strong>
            </p>
          </div>
        </div>

        <% if (user) { %>
          <form method="POST" action="/products/<%= product.id %>/comments" enctype="multipart/form-data"
            class="mt-5 space-y-3">
            <textarea name="text" required placeholder="Escreva seu comentário"
              class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring"></textarea>

            <input type="file" name="commentPhoto"
              class="w-full rounded-xl border border-brand-300 px-4 py-2.5 bg-white text-sm text-brand-700 outline-none hover:bg-brand-100 focus:ring-accent-500 focus:ring">

            <button class="rounded-xl bg-accent-500 px-5 py-2.5 font-semibold text-black hover:bg-accent-600">
              Comentar
            </button>
          </form>
          <% } else { %>
            <p class="mt-4 rounded-xl bg-brand-100 px-4 py-3 text-sm text-brand-700">
              Faça login para comentar e curtir.
            </p>
            <% } %>

              <div class="mt-6 space-y-4">
                <% if (product.comments.length===0) { %>
                  <p class="text-sm text-brand-700">Nenhum comentário ainda.</p>
                  <% } %>

                    <% product.comments.forEach(comment=> { %>
                      <article class="rounded-2xl border border-brand-200 bg-brand-50 p-4">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <p class="font-semibold">
                              <%= comment.user.name %>
                            </p>
                            <p class="text-xs text-brand-600">
                              <%= new Date(comment.createdAt).toLocaleString('pt-BR') %>
                            </p>
                          </div>

                          <% if (user && (comment.userId===user.id || user.tipo_usuario==='admin' || user.tipo_usuario==='Admin' )) { %>
                            <form method="POST" action="/comments/<%= comment.id %>/delete">
                              <button
                                class="rounded-lg bg-coral-500 px-3 py-1.5 text-xs font-semibold text-black hover:bg-coral-600">
                                Excluir
                              </button>
                            </form>
                            <% } %>
                        </div>

                        <p class="mt-3 text-sm text-brand-800">
                          <%= comment.text %>
                        </p>

                        <% if (user && comment.userId === user.id) { %>
                          <form method="POST" action="/comments/<%= comment.id %>/edit" class="mt-3 flex gap-2">
                            <input name="text" value="<%= comment.text %>" required class="flex-1 rounded-lg border border-brand-300 px-3 py-1.5 text-sm outline-none ring-accent-500 focus:ring">
                            <button class="rounded-lg border border-brand-300 px-3 py-1.5 text-xs font-semibold hover:bg-brand-100">Editar</button>
                          </form>
                        <% } %>

                        <% if (comment.photoUrl) { %>
                          <img src="<%= comment.photoUrl %>"
                            class="mt-3 h-40 rounded-xl object-cover border border-brand-200">
                          <% } %>

                            <div class="mt-4 flex items-center gap-3">
                              <span class="text-sm font-semibold">
                                <%= comment.likes.length %> curtida(s)
                              </span>

                              <% if (user) { %>
                                <form method="POST" action="/comments/<%= comment.id %>/like">
                                  <button
                                    class="rounded-lg border border-brand-300 px-3 py-1.5 text-sm font-semibold hover:bg-brand-100">
                                    Curtir / Remover curtida
                                  </button>
                                </form>
                                <% } %>
                            </div>
                      </article>
                      <% }) %>
              </div>
      </section>
    </main>
  </div>
</body>

</html>