<!doctype html>
<html lang="pt-BR">

<head>
    <title>MarketMVP | Perfil público do vendedor</title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
        <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
            <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
                <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
                <a href="/marketplace" class="text-sm font-semibold hover:text-accent-600">Ver produtos</a>
            </div>
        </header>

        <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
            <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Vendedor</p>

                <h1 class="mt-1 font-display text-3xl font-bold">
                    <%= seller.sellerProfile?.storeName || seller.name %>
                </h1>

                <% if (seller.sellerProfile) { %>
                    <p class="mt-3 text-brand-700">
                        <%= seller.sellerProfile.description %>
                    </p>

                    <div class="mt-5 grid gap-3 sm:grid-cols-3">
                        <div class="rounded-2xl bg-brand-100 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wider">Contato</p>
                            <p class="mt-1 font-semibold">
                                <%= seller.sellerProfile.commercialPhone %>
                            </p>
                        </div>

                        <div class="rounded-2xl bg-brand-100 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wider">Cidade</p>
                            <p class="mt-1 font-semibold">
                                <%= seller.sellerProfile.city %> - <%= seller.sellerProfile.state %>
                            </p>
                        </div>

                        <div class="rounded-2xl bg-brand-100 p-4">
                            <p class="text-xs font-semibold uppercase tracking-wider">Categorias</p>
                            <p class="mt-1 font-semibold">
                                <%= seller.sellerProfile.categories %>
                            </p>
                        </div>
                    </div>
                    <% } else { %>
                        <p class="mt-3 text-brand-700">Este vendedor ainda não completou o perfil público.</p>
                        <% } %>
            </section>

            <section>
                <h2 class="mb-4 font-display text-2xl font-bold">Produtos deste vendedor</h2>

                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    <% seller.products.forEach(product=> { %>
                        <article class="rounded-2xl border border-brand-200 bg-white p-4 shadow-sm">
                            <% if (product.imageUrl) { %>
                                <img src="<%= product.imageUrl %>"
                                    class="h-44 w-full rounded-xl object-cover border border-brand-200">
                                <% } else { %>
                                    <div
                                        class="flex h-44 items-center justify-center rounded-xl bg-brand-100 text-sm text-brand-700">
                                        Sem imagem
                                    </div>
                                    <% } %>

                                        <p class="mt-3 text-xs font-semibold uppercase tracking-wider text-brand-600">
                                            <%= product.category %>
                                        </p>

                                        <h3 class="mt-1 font-display text-lg font-bold">
                                            <%= product.name %>
                                        </h3>

                                        <p class="mt-1 text-sm text-brand-700">
                                            <%= product.description %>
                                        </p>

                                        <div class="mt-3 flex items-center justify-between">
                                            <span class="font-bold text-coral-600">
                                                R$ <%= Number(product.price).toFixed(2).replace('.', ',' ) %>
                                            </span>

                                            <a href="/products/<%= product.id %>"
                                                class="rounded-lg border border-brand-300 px-3 py-1.5 text-sm font-semibold hover:bg-brand-100">
                                                Ver
                                            </a>
                                        </div>
                        </article>
                        <% }) %>
                </div>
            </section>
        </main>
    </div>
</body>

</html>