<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <title>Editar Produto</title>
<%- include('_head') %>
</head>

<body class="bg-gray-100">

    <main class="max-w-3xl mx-auto px-4 py-8">

        <h1 class="text-2xl font-bold mb-6">
            Editar Produto
        </h1>

        <form action="/seller/products/<%= product.id %>/edit" method="POST" enctype="multipart/form-data"
            class="bg-white p-6 rounded shadow space-y-4">

            <div>
                <label class="block font-semibold mb-1">Nome do produto</label>
                <input type="text" name="name" value="<%= product.name %>" class="w-full border rounded px-3 py-2"
                    required>
            </div>

            <div>
                <label class="block font-semibold mb-1">Descrição</label>
                <textarea name="description" class="w-full border rounded px-3 py-2"
                    required><%= product.description %></textarea>
            </div>

            <div>
                <label class="block font-semibold mb-1">Categoria</label>
                <select name="category" class="w-full border rounded px-3 py-2" required>
                    <% categoriasValidas.forEach(categoria=> { %>
                        <option value="<%= categoria %>" <%=product.category===categoria ? 'selected' : '' %>
                            >
                            <%= categoria %>
                        </option>
                        <% }) %>
                </select>
            </div>

            <div>
                <label class="block font-semibold mb-1">Preço</label>
                <input type="number" step="0.01" name="price" value="<%= product.price %>"
                    class="w-full border rounded px-3 py-2" required>
            </div>

            <div>
                <label class="block font-semibold mb-1">Estoque</label>
                <input type="number" name="stock" value="<%= product.stock %>" class="w-full border rounded px-3 py-2"
                    required>
            </div>

            <div>
                <label class="block font-semibold mb-1">Novas imagens</label>
                <input type="file" name="images" multiple class="w-full border rounded px-3 py-2">
            </div>

            <div class="flex gap-3">
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">
                    Salvar Alterações
                </button>

                <a href="/seller/products" class="bg-gray-500 text-white px-4 py-2 rounded">
                    Cancelar
                </a>
            </div>

        </form>

    </main>

</body>

</html>