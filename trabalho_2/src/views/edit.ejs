<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <title>Editar Produto</title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
        <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
            <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
                <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
                <a href="/seller/products" class="text-sm font-semibold hover:text-accent-600">Voltar</a>
            </div>
        </header>

        <main class="mx-auto max-w-3xl px-4 py-8">
            <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Vendedor</p>
                <h1 class="mt-1 font-display text-3xl font-bold">Editar produto</h1>

                <form action="/seller/products/<%= product.id %>/edit" method="POST" enctype="multipart/form-data"
                    class="mt-5 grid gap-4 sm:grid-cols-2">

                    <label class="block sm:col-span-2">
                        <span class="mb-1 block text-sm font-medium">Nome do produto</span>
                        <input type="text" name="name" value="<%= product.name %>" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block sm:col-span-2">
                        <span class="mb-1 block text-sm font-medium">Descrição</span>
                        <textarea name="description" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring"><%= product.description %></textarea>
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Categoria</span>
                        <select name="category" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                            <% categoriasValidas.forEach(categoria=> { %>
                                <option value="<%= categoria %>" <%=product.category===categoria ? 'selected' : '' %>>
                                    <%= categoria %>
                                </option>
                                <% }) %>
                        </select>
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Status</span>
                        <select name="isActive" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                            <option value="true" <%=product.isActive ? 'selected' : '' %>>Ativo</option>
                            <option value="false" <%=!product.isActive ? 'selected' : '' %>>Desativado</option>
                        </select>
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Preço</span>
                        <input type="number" step="0.01" name="price" value="<%= product.price %>" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Estoque</span>
                        <input type="number" name="stock" value="<%= product.stock %>" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <% if (product.imageUrl) { %>
                        <div class="sm:col-span-2">
                            <span class="mb-1 block text-sm font-medium">Imagem atual</span>
                            <img src="<%= product.imageUrl %>" class="h-40 rounded-2xl object-cover">
                        </div>
                        <% } %>

                            <label class="block sm:col-span-2">
                                <span class="mb-1 block text-sm font-medium">Novas imagens</span>
                                <input type="file" name="images" multiple
                                    class="w-full rounded-xl border border-brand-300 bg-white px-4 py-2.5">
                                <span class="mt-1 block text-xs text-brand-600">
                                    Só envie novas imagens se quiser substituir as atuais.
                                </span>
                            </label>

                            <div class="flex gap-3 sm:col-span-2">
                                <button type="submit"
                                    class="rounded-xl bg-accent-500 px-5 py-2.5 font-semibold text-black hover:bg-accent-600">
                                    Salvar alterações
                                </button>

                                <a href="/seller/products"
                                    class="rounded-xl bg-gray-500 px-5 py-2.5 font-semibold text-white hover:bg-gray-600">
                                    Cancelar
                                </a>
                            </div>
                </form>
            </section>
        </main>
    </div>
</body>

</html>