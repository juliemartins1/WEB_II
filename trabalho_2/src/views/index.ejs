<!doctype html>
<html lang="pt-BR">

<head>
    <title>MarketMVP | Painel administrativo</title>
    <%- include('_head') %>
</head>

    <body class="bg-gray-100">

        <div class="max-w-6xl mx-auto py-8">

            <div class="flex justify-between items-center mb-6">
                <h1 class="text-3xl font-bold">
                    Gerenciar Produtos
                </h1>

                <a href="/seller/products/new" class="bg-blue-600 text-white px-4 py-2 rounded">
                    Novo Produto
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                <% products.forEach(product=> { %>

                    <div class="bg-white p-4 rounded shadow">

                        <% if(product.imageUrl){ %>
                            <img src="<%= product.imageUrl %>" class="w-full h-48 object-cover rounded mb-4">
                            <% } %>

                                <h2 class="text-xl font-bold">
                                    <%= product.name %>
                                </h2>

                                <p class="text-gray-600 mb-2">
                                    <%= product.category %>
                                </p>

                                <p class="text-green-600 font-bold mb-4">
                                    R$ <%= product.price %>
                                </p>

                                <div class="flex gap-2">

                                    <a href="/seller/products/<%= product.id %>/edit"
                                        class="bg-yellow-500 text-white px-3 py-2 rounded">
                                        Editar
                                    </a>

                                    <form action="/seller/products/<%= product.id %>/delete" method="POST">
                                        <button class="bg-red-600 text-white px-3 py-2 rounded">
                                            Excluir
                                        </button>
                                    </form>

                                </div>

                    </div>

                    <% }) %>

            </div>

        </div>

    </body>