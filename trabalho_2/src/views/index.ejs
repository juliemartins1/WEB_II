<!doctype html>
<html lang="pt-BR">
<head>
  <title>MarketMVP | Início</title>
  <%- include('_head') %>
</head>
<body class="font-body bg-brand-50 text-brand-900">
  <div class="min-h-screen grid-bg">
    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
        <nav class="flex items-center gap-5 text-sm font-medium">
          <a href="/marketplace" class="hover:text-accent-600">Produtos</a>
          <% if (user) { %>
            <% if (user.tipo_usuario === 'comprador') { %><a href="/profiles/buyer" class="hover:text-accent-600">Meu perfil</a><% } %>
            <% if (user.tipo_usuario === 'vendedor') { %><a href="/seller" class="hover:text-accent-600">Painel vendedor</a><% } %>
            <% if (user.tipo_usuario === 'admin') { %><a href="/admin/users" class="hover:text-accent-600">Admin</a><% } %>
            <span class="text-brand-600">Olá, <%= user.name %></span>
            <form method="POST" action="/logout"><button type="submit" class="hover:text-accent-600">Sair</button></form>
          <% } else { %>
            <a href="/login" class="hover:text-accent-600">Entrar</a>
            <a href="/signup" class="rounded-full bg-brand-900 px-4 py-2 text-sm font-semibold text-brand-50 hover:bg-brand-800">Criar conta</a>
          <% } %>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl space-y-8 px-4 py-8 sm:px-6 lg:px-8">
      <section class="rounded-3xl border border-brand-200 bg-white/85 p-6 shadow-sm md:p-8">
        <p class="mb-2 inline-flex rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-700">Marketplace</p>
        <h1 class="font-display text-3xl font-bold leading-tight sm:text-4xl">Descubra produtos de vendedores independentes.</h1>
        <p class="mt-4 max-w-xl text-brand-700">Veja produtos, detalhes, vendedor, comentários e curtidas.</p>
      </section>

      <section>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="font-display text-2xl font-bold">Produtos em destaque</h2>
          <% if (user && user.tipo_usuario === 'vendedor') { %>
            <a href="/seller/products/new" class="rounded-xl bg-accent-500 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-600">Cadastrar produto</a>
          <% } %>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <% if (!products || products.length === 0) { %>
            <p class="text-brand-700">Nenhum produto cadastrado ainda.</p>
          <% } %>
          <% products.forEach(product => { %>
            <article class="rounded-2xl border border-brand-200 bg-white p-4 shadow-sm">
              <% if (product.imageUrl) { %>
                <img src="<%= product.imageUrl %>" class="mb-3 h-44 w-full rounded-xl object-cover border border-brand-200">
              <% } %>
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-600"><%= product.category %></p>
              <h3 class="mt-1 font-display text-lg font-bold"><%= product.name %></h3>
              <p class="mt-1 text-sm text-brand-700 line-clamp-2"><%= product.description %></p>
              <p class="mt-2 text-sm text-brand-700">Vendedor: <strong><%= product.user.sellerProfile?.storeName || product.user.name %></strong></p>
              <div class="mt-3 flex items-center justify-between">
                <span class="font-bold text-coral-600">R$ <%= Number(product.price).toFixed(2).replace('.', ',') %></span>
                <a href="/products/<%= product.id %>" class="rounded-lg border border-brand-300 px-3 py-1.5 text-sm font-semibold hover:bg-brand-100">Ver detalhes</a>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
