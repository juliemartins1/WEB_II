<!doctype html>
<html lang="pt-BR">

<head>
    <title>MarketMVP | Pedidos recebidos</title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">

    <div class="min-h-screen grid-bg">

        <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
            <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">

                <a href="/" class="font-display text-xl font-bold">
                    MarketMVP
                </a>

                <nav class="flex items-center gap-5 text-sm font-medium">
                    <a href="/seller" class="hover:text-accent-600">Painel do vendedor</a>
                    <a href="/marketplace" class="hover:text-accent-600">Marketplace</a>

                    <form method="POST" action="/logout">
                        <button type="submit" class="hover:text-accent-600">
                            Sair
                        </button>
                    </form>
                </nav>

            </div>
        </header>

        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">

            <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">

                <h1 class="font-display text-3xl font-bold">
                    Pedidos recebidos
                </h1>

                <% if (orders.length===0) { %>

                    <p class="mt-6 text-brand-700">
                        Nenhum pedido recebido ainda.
                    </p>

                    <% } else { %>

                        <div class="mt-6 overflow-x-auto">

                            <table class="min-w-full rounded-2xl border border-brand-200">

                                <thead class="bg-brand-100 text-left text-sm font-semibold text-brand-700">
                                    <tr>
                                        <th class="px-4 py-3">Produto</th>
                                        <th class="px-4 py-3">Comprador</th>
                                        <th class="px-4 py-3">Quantidade</th>
                                        <th class="px-4 py-3">Total</th>
                                        <th class="px-4 py-3">Status</th>
                                        <th class="px-4 py-3">Data</th>
                                    </tr>
                                </thead>

                                <tbody class="bg-white text-sm">

                                    <% orders.forEach(order=> { %>

                                        <tr class="border-t border-brand-200">

                                            <td class="px-4 py-3">
                                                <%= order.product.name %>
                                            </td>

                                            <td class="px-4 py-3">
                                                <%= order.buyer.name %>
                                            </td>

                                            <td class="px-4 py-3">
                                                <%= order.quantity %>
                                            </td>

                                            <td class="px-4 py-3 font-semibold">
                                                R$ <%= Number(order.total).toFixed(2) %>
                                            </td>

                                            <td class="px-4 py-3">
                                                <span
                                                    class="rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-700">
                                                    <%= order.status %>
                                                </span>
                                            </td>

                                            <td class="px-4 py-3">
                                                <%= new Date(order.createdAt).toLocaleString('pt-BR') %>
                                            </td>

                                        </tr>

                                        <% }) %>

                                </tbody>

                            </table>

                        </div>

                        <% } %>

            </section>

        </main>

    </div>

</body>

</html>