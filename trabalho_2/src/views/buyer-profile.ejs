<!doctype html>
<html lang="pt-BR">

<head>
    <title>Perfil do comprador</title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Perfil: Comprador</p>
            <h1 class="mt-1 font-display text-3xl font-bold">Meus dados</h1>

            <% if (success) { %>
                <p class="mt-3 rounded-xl bg-accent-500/10 px-4 py-2 text-sm font-semibold text-accent-600">
                    <%= success %>
                </p>
                <% } %>

                    <% if (error) { %>
                        <p class="mt-3 rounded-xl bg-coral-500/10 px-4 py-2 text-sm font-semibold text-coral-600">
                            <%= error %>
                        </p>
                        <% } %>

                            <form method="POST" action="/profiles/buyer" class="mt-5 grid gap-4 sm:grid-cols-2">
                                <label>
                                    <span class="mb-1 block text-sm font-medium">Telefone</span>
                                    <input name="phone" required value="<%= profile?.phone || '' %>"
                                        class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                </label>

                                <label>
                                    <span class="mb-1 block text-sm font-medium">CEP</span>
                                    <input name="zipCode" required value="<%= profile?.zipCode || '' %>"
                                        class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                </label>

                                <label class="sm:col-span-2">
                                    <span class="mb-1 block text-sm font-medium">Endereço completo</span>
                                    <input name="address" required value="<%= profile?.address || '' %>"
                                        class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                </label>

                                <label>
                                    <span class="mb-1 block text-sm font-medium">Cidade</span>
                                    <input name="city" required value="<%= profile?.city || '' %>"
                                        class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                </label>

                                <label>
                                    <span class="mb-1 block text-sm font-medium">Estado</span>
                                    <input name="state" required maxlength="2" value="<%= profile?.state || '' %>"
                                        class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                </label>

                                <label class="sm:col-span-2">
                                    <span class="mb-1 block text-sm font-medium">Forma de pagamento preferencial</span>
                                    <select name="paymentMethod" required
                                        class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                                        <option value="">Selecione</option>
                                        <option value="Pix" <%=profile?.paymentMethod==='Pix' ? 'selected' : '' %>>Pix</option>
                                        <option value="Cartão de crédito" <%=profile?.paymentMethod==='Cartão de crédito' ? 'selected' : '' %>>Cartão de
                                            crédito</option>
                                        <option value="Cartão de débito" <%=profile?.paymentMethod==='Cartão de débito' ? 'selected' : '' %>>Cartão de
                                            débito</option>
                                        <option value="Boleto" <%=profile?.paymentMethod==='Boleto' ? 'selected' : '' %>>Boleto</option>
                                    </select>
                                </label>

                                <button type="submit"
                                    class="sm:col-span-2 rounded-xl bg-accent-500 px-5 py-2.5 font-semibold text-black hover:bg-accent-600">
                                    Salvar perfil
                                </button>
                            </form>
        </section>
    </main>
</body>

</html>