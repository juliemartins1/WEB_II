<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <title>Gerenciar Produtos</title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
        <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
            <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
                <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
                <nav class="flex items-center gap-5 text-sm font-medium">
                    <a href="/seller" class="hover:text-accent-600">Painel</a>
                    <a href="/seller/products/new" class="hover:text-accent-600">Novo produto</a>
                    <form method="POST" action="/logout">
                        <button type="submit" class="hover:text-accent-600">Sair</button>
                    </form>
                </nav>
            </div>
        </header>

        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
            <div class="mb-6 flex items-center justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Vendedor</p>
                    <h1 class="mt-1 font-display text-3xl font-bold">Meus produtos</h1>
                </div>

                <a href="/seller/products/new"
                    class="rounded-xl bg-accent-500 px-4 py-2 font-semibold text-black hover:bg-accent-600">
                    Novo produto
                </a>
            </div>

            <% if (success) { %>
                <div class="mb-4 rounded-xl bg-green-100 px-4 py-3 text-green-800">
                    <%= success %>
                </div>
                <% } %>

                    <% if (error) { %>
                        <div class="mb-4 rounded-xl bg-red-100 px-4 py-3 text-red-800">
                            <%= error %>
                        </div>
                        <% } %>

                            <% if (products.length===0) { %>
                                <div class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
                                    Nenhum produto cadastrado.
                                </div>
                                <% } %>

                                    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
                                        <% products.forEach(product=> { %>
                                            <div class="rounded-3xl border border-brand-200 bg-white p-4 shadow-sm">
                                                <% if (product.imageUrl) { %>
                                                    <img src="<%= product.imageUrl %>"
                                                        class="mb-4 h-48 w-full rounded-2xl object-cover">
                                                    <% } else { %>
                                                        <div
                                                            class="mb-4 flex h-48 items-center justify-center rounded-2xl bg-brand-100 text-sm text-brand-600">
                                                            Sem imagem
                                                        </div>
                                                        <% } %>

                                                            <div class="mb-2 flex items-center justify-between gap-2">
                                                                <h2 class="text-xl font-bold">
                                                                    <%= product.name %>
                                                                </h2>

                                                                <% if (product.isActive) { %>
                                                                    <span
                                                                        class="rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">Ativo</span>
                                                                    <% } else { %>
                                                                        <span
                                                                            class="rounded-full bg-gray-200 px-3 py-1 text-xs font-semibold text-gray-700">Desativado</span>
                                                                        <% } %>
                                                            </div>

                                                            <p class="mb-2 text-sm text-brand-600">
                                                                <%= product.category %>
                                                            </p>
                                                            <p class="mb-1 font-bold text-green-700">R$ <%=
                                                                    Number(product.price).toFixed(2) %>
                                                            </p>
                                                            <p class="mb-4 text-sm text-brand-700">Estoque: <%=
                                                                    product.stock %>
                                                            </p>

                                                            <div class="flex flex-wrap gap-2">
                                                                <a href="/seller/products/<%= product.id %>/edit"
                                                                    class="rounded-lg bg-yellow-500 px-3 py-2 text-sm font-semibold text-white hover:bg-yellow-600">
                                                                    Editar
                                                                </a>

                                                                <form action="/seller/products/<%= product.id %>/toggle"
                                                                    method="POST">
                                                                    <button type="submit"
                                                                        class="rounded-lg bg-gray-700 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800">
                                                                        <%= product.isActive ? 'Desativar' : 'Ativar' %>
                                                                    </button>
                                                                </form>

                                                                <form action="/seller/products/<%= product.id %>/delete"
                                                                    method="POST">
                                                                    <button type="submit"
                                                                        onclick="return confirm('Deseja excluir este produto?')"
                                                                        class="rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-700">
                                                                        Excluir
                                                                    </button>
                                                                </form>
                                                            </div>
                                            </div>
                                            <% }) %>
                                    </div>
        </main>
    </div>
</body>

</html>