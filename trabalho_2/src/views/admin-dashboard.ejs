<!doctype html>
<html lang="pt-BR">

<head>
  <title>Painel administrativo</title>
  <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
  <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">

    <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">
            Controle global da plataforma
          </p>
          <h1 class="mt-1 font-display text-3xl font-bold">Painel administrativo</h1>
          <p class="mt-2 max-w-2xl text-sm text-brand-700">
            Acompanhe contas cadastradas e desative acessos quando necessário.
          </p>
        </div>

        <div class="rounded-2xl bg-brand-100 px-4 py-3 text-sm font-semibold text-brand-800">
          Administrador autenticado:
          <%= user ? user.email || user.name : 'Administrador' %>
        </div>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl bg-brand-100 p-4">
          <p class="text-xs font-semibold uppercase tracking-wider">Contas totais</p>
          <p class="mt-2 font-display text-3xl font-bold">
            <%= users.length %>
          </p>
        </div>

        <div class="rounded-2xl bg-brand-100 p-4">
          <p class="text-xs font-semibold uppercase tracking-wider">Contas ativas</p>
          <p class="mt-2 font-display text-3xl font-bold">
            <%= users.filter(u=> u.active).length %>
          </p>
        </div>

        <div class="rounded-2xl bg-brand-100 p-4">
          <p class="text-xs font-semibold uppercase tracking-wider">Contas desativadas</p>
          <p class="mt-2 font-display text-3xl font-bold">
            <%= users.filter(u=> !u.active).length %>
          </p>
        </div>
      </div>
    </section>

    <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 class="font-display text-2xl font-bold">Lista de contas</h2>
          <p class="mt-1 text-sm text-brand-700">
            Visualize compradores, vendedores e administradores cadastrados pelo sistema.
          </p>
        </div>
      </div>

      <div class="mt-4 overflow-x-auto rounded-2xl border border-brand-200">
        <table class="min-w-full text-left text-sm">
          <thead class="bg-brand-100 text-brand-800">
            <tr>
              <th class="px-4 py-3 font-semibold">Conta</th>
              <th class="px-4 py-3 font-semibold">Perfil</th>
              <th class="px-4 py-3 font-semibold">E-mail</th>
              <th class="px-4 py-3 font-semibold">Último acesso</th>
              <th class="px-4 py-3 font-semibold">Status</th>
              <th class="px-4 py-3 font-semibold">Ações</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-brand-200 bg-white">
            <% if (!users || users.length===0) { %>
              <tr>
                <td colspan="6" class="px-4 py-6 text-center text-brand-600">
                  Nenhuma conta cadastrada.
                </td>
              </tr>
              <% } %>

                <% users.forEach(account=> { %>
                  <tr>
                    <td class="px-4 py-3 font-semibold">
                      <%= account.name %>
                    </td>

                    <td class="px-4 py-3">
                      <%= account.tipo_usuario %>
                    </td>

                    <td class="px-4 py-3">
                      <%= account.email %>
                    </td>

                    <td class="px-4 py-3">
                      <%= account.lastLoginAt ? new Date(account.lastLoginAt).toLocaleString('pt-BR') : 'Nunca acessou'
                        %>
                    </td>

                    <td class="px-4 py-3">
                      <% if (account.active) { %>
                        <span class="rounded-full bg-accent-500/10 px-2 py-1 text-xs font-semibold text-accent-600">
                          Ativa
                        </span>
                        <% } else { %>
                          <span class="rounded-full bg-brand-200 px-2 py-1 text-xs font-semibold text-brand-700">
                            Desativada
                          </span>
                          <% } %>
                    </td>

                    <td class="px-4 py-3">
                      <% if (user && user.id !==account.id) { %>
                        <form action="/admin/users/<%= account.id %>/toggle" method="POST">
                          <button type="submit"
                            class="<%= account.active ? 'rounded-lg bg-coral-500 px-3 py-1.5 font-semibold text-white hover:bg-coral-600' : 'rounded-lg border border-brand-300 px-3 py-1.5 font-semibold hover:bg-brand-100' %>">
                            <%= account.active ? 'Desativar conta' : 'Reativar conta' %>
                          </button>
                        </form>
                        <% } else { %>
                          <span class="text-xs text-brand-500">Sua conta</span>
                          <% } %>
                    </td>
                  </tr>
                  <% }) %>
          </tbody>
        </table>
      </div>
    </section>

  </main>
</body>

</html>