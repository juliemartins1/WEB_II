<!doctype html>
<html lang="pt-BR">

<head>
    <title> <%= product ? 'Editar produto' : 'Novo produto' %></title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
       

        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
            <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Vendedor</p>
                <h1 class="mt-1 font-display text-3xl font-bold">
                    <%= product ? 'Editar produto' : 'Cadastrar produto' %>
                </h1>
                <p class="mt-2 text-sm text-brand-700">
                    <%= product ? 'Atualize os dados do produto e adicione novas fotos se desejar.' : 'Adicione descrição, preço, estoque e múltiplas fotos.' %>
                </p>

                <% if (error) { %>
                    <div class="mt-4 rounded-xl bg-red-100 px-4 py-3 text-sm font-medium text-red-700">
                        <%= error %>
                    </div>
                <% } %>

                <form method="POST"
                    action="<%= product ? '/seller/products/' + product.id + '/edit' : '/seller/products' %>"
                    enctype="multipart/form-data"
                    class="mt-5 grid gap-4 sm:grid-cols-2">

                    <label class="block sm:col-span-2">
                        <span class="mb-1 block text-sm font-medium">Nome do produto</span>
                        <input name="name" required value="<%= product ? product.name : '' %>"
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block sm:col-span-2">
                        <span class="mb-1 block text-sm font-medium">Descrição</span>
                        <textarea name="description" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring"><%= product ? product.description : '' %></textarea>
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Categoria</span>
                        <select name="category" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                            <option value="">Selecione uma categoria</option>
                            <% const categorias = ['Eletrônicos', 'Casa e decoração', 'Moda', 'Esportes', 'Beleza', 'Automotivo', 'Outros']; %>
                            <% categorias.forEach(function(categoria) { %>
                                <option value="<%= categoria %>" <%= product && product.category === categoria ? 'selected' : '' %>>
                                    <%= categoria %>
                                </option>
                            <% }) %>
                        </select>
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Preço</span>
                        <input type="number" step="0.01" name="price" required value="<%= product ? product.price : '' %>"
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Estoque</span>
                        <input type="number" name="stock" required value="<%= product ? product.stock : '' %>"
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">
                            <%= product ? 'Adicionar novas fotos' : 'Fotos do produto' %>
                        </span>
                        <input type="file" name="images" multiple accept="image/jpeg,image/png,image/webp"
                            class="w-full rounded-xl border border-brand-300 bg-white px-4 py-2.5">
                        <span class="mt-1 block text-xs text-brand-600">JPG, PNG ou WEBP. Até 5 fotos por envio.</span>
                    </label>

                    <% if (product && product.images && product.images.length > 0) { %>
                        <div class="sm:col-span-2">
                            <p class="mb-2 text-sm font-medium">Fotos já cadastradas</p>
                            <div class="grid gap-3 sm:grid-cols-4">
                                <% product.images.forEach(function(image) { %>
                                    <div class="overflow-hidden rounded-xl border border-brand-200 bg-brand-50">
                                        <img src="<%= image.imageUrl %>" class="h-28 w-full object-cover" alt="Foto do produto">
                                        <% if (image.isMain) { %>
                                            <p class="px-2 py-1 text-xs font-semibold text-brand-700">Principal</p>
                                        <% } %>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <button class="sm:col-span-2 rounded-xl bg-accent-500 px-5 py-2.5 font-semibold text-black hover:bg-accent-600">
                        <%= product ? 'Salvar alterações' : 'Cadastrar produto' %>
                    </button>
                </form>
            </section>
        </main>
    </div>
</body>

</html>
