<!doctype html>
<html lang="pt-BR">

<head>
    <title>MarketMVP | Novo produto</title>
    <%- include('_head') %>
</head>

<body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
        <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
            <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
                <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
                <a href="/seller" class="text-sm font-semibold hover:text-accent-600">Voltar ao painel</a>
            </div>
        </header>

        <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
            <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Vendedor</p>
                <h1 class="mt-1 font-display text-3xl font-bold">Cadastrar produto</h1>
                <p class="mt-2 text-sm text-brand-700">Adicione descrição, preço, estoque e múltiplas fotos.</p>

                <form method="POST" action="/seller/products" enctype="multipart/form-data"
                    class="mt-5 grid gap-4 sm:grid-cols-2">
                    <label class="block sm:col-span-2">
                        <span class="mb-1 block text-sm font-medium">Nome do produto</span>
                        <input name="name" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block sm:col-span-2">
                        <span class="mb-1 block text-sm font-medium">Descrição</span>
                        <textarea name="description" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring"></textarea>
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Categoria</span>
                        <select name="category" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                        
                            <option value="">Selecione uma categoria</option>
                        
                            <option value="Eletrônicos">Eletrônicos</option>
                            <option value="Casa e decoração">Casa e decoração</option>
                            <option value="Moda">Moda</option>
                            <option value="Esportes">Esportes</option>
                            <option value="Beleza">Beleza</option>
                            <option value="Automotivo">Automotivo</option>
                            <option value="Outros">Outros</option>
                        
                        </select>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Preço</span>
                        <input type="number" step="0.01" name="price" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Estoque</span>
                        <input type="number" name="stock" required
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-accent-500 focus:ring">
                    </label>

                    <label class="block">
                        <span class="mb-1 block text-sm font-medium">Fotos do produto</span>
                        <input type="file" name="images" multiple
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 bg-white">
                    </label>

                    <button
                        class="sm:col-span-2 rounded-xl bg-accent-500 px-5 py-2.5 font-semibold text-black hover:bg-accent-600">
                        Cadastrar produto
                    </button>
                </form>
            </section>
        </main>
    </div>
</body>

</html>